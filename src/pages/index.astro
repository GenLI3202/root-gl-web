---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Fetch featured posts (most recent 5)
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

// Format date
function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
}

const projects = [
  {
    title: "MAMODA Web Dashboard",
    description: "Interactive knowledge hub for sustainable mining decisions. Multi-objective optimization with stakeholder-guided decision-making.",
    tags: ["Python", "FastAPI", "Plotly"],
    href: "https://mamoda-web-dashboard.vercel.app/",
  },
  {
    title: "Accross Cycling Club",
    description: "Event registration and results platform for Munich's Accross Cycling Club. Club management software built with Astro.",
    tags: ["Astro", "TypeScript"],
    href: "#",
  },
  {
    title: "EV Charging Optimizer",
    description: "Stochastic MILP model for optimal EV charging station placement under grid uncertainty. PCT patent WO2025026594.",
    tags: ["Python", "Pyomo", "CPLEX"],
    href: "https://patentscope.wipo.int/search/en/detail.jsf?docId=WO2025026594",
  },
];

const identityTags = [
  { label: "⚡ Energy Research", title: "Energy systems optimization" },
  { label: "🚴 Cyclist", title: "Accross Cycling Club Munich" },
  { label: "📖 Reader", title: "Sci-fi, Wuxia, Literature" },
  { label: "🎸 Guitar", title: "Acoustic guitar" },
];
---

<BaseLayout>
  <!-- ── Hero ─────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <h1 class="hero-name">Gen Li</h1>
        <p class="hero-tagline">
          PhD Researcher at TU Munich.<br />
          Optimizing energy systems by day,<br />
          leading cyclists through Munich by night.
        </p>
        <div class="hero-tags">
          {identityTags.map(({ label, title }) => (
            <span class="identity-tag" title={title}>{label}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Recent Posts ──────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Recent Writing</h2>
        <a href="/posts/" class="section-link">All posts →</a>
      </div>

      {recentPosts.length === 0 ? (
        <p class="empty-state">Posts coming soon.</p>
      ) : (
        <ul class="post-list" role="list">
          {recentPosts.map((post) => (
            <li class="post-item">
              <a href={`/posts/${post.id}/`} class="post-link">
                <span class="post-title">{post.data.title}</span>
                <span class="post-date">{formatDate(post.data.pubDate)}</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <hr class="divider" />

  <!-- ── Selected Projects ─────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Selected Projects</h2>
        <a href="/projects/" class="section-link">All projects →</a>
      </div>

      <ul class="project-list" role="list">
        {projects.map((project) => (
          <li class="project-card">
            <a href={project.href} class="project-link" target="_blank" rel="noopener noreferrer">
              <div class="project-content">
                <h3 class="project-title">{project.title}</h3>
                <p class="project-desc">{project.description}</p>
                <div class="project-tags">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
              <span class="project-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding-top: 5rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    max-width: 560px;
  }

  .hero-name {
    font-size: var(--text-hero);
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .identity-tag {
    font-size: var(--text-sm);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    cursor: default;
    transition: border-color var(--transition), color var(--transition);
  }

  .identity-tag:hover {
    border-color: var(--accent);
    color: var(--fg);
  }

  /* ── Sections ── */
  .section {
    padding-block: 3rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .section-title {
    font-size: var(--text-xl);
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .section-link {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition);
  }

  .section-link:hover {
    color: var(--accent);
  }

  .divider {
    border: none;
    border-top: 1px solid var(--border);
  }

  .empty-state {
    color: var(--fg-muted);
    font-style: italic;
  }

  /* ── Post list ── */
  .post-list {
    list-style: none;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }
  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.875rem;
    text-decoration: none;
    transition: color var(--transition);
  }

  .post-title {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--fg);
    transition: color var(--transition);
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Project list ── */
  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-card {
    border-bottom: 1px solid var(--border);
  }
  .project-card:first-child {
    border-top: 1px solid var(--border);
  }

  .project-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.25rem;
    text-decoration: none;
  }

  .project-content {
    flex: 1;
  }

  .project-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.375rem;
    transition: color var(--transition);
    font-family: var(--font-body);
  }

  .project-link:hover .project-title {
    color: var(--accent);
  }

  .project-desc {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .project-arrow {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--transition), transform var(--transition), color var(--transition);
  }

  .project-link:hover .project-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }
</style>
