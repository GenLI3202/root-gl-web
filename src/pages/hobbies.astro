---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CharacterCarousel from "@/components/CharacterCarousel.astro";
---

<BaseLayout title="Hobbies · Gen Li" description="Cycling, reading, and guitar — life beyond the whiteboard.">
  <div class="hobbies-page">

    <!-- Page header -->
    <header class="hobbies-header">
      <h1 class="hobbies-title">Life Beyond the Whiteboard</h1>
      <p class="hobbies-intro">
        Optimisation keeps the mind sharp. Everything below keeps the rest of me alive.
      </p>
    </header>

    <!-- Section tabs -->
    <div class="scene-tabs" role="tablist" aria-label="Hobby sections">
      <button class="scene-tab active" data-scene="0" role="tab" aria-selected="true">
        <span class="tab-icon">🚴</span> Cycling
      </button>
      <button class="scene-tab" data-scene="1" role="tab" aria-selected="false">
        <span class="tab-icon">📖</span> Reading
      </button>
      <button class="scene-tab" data-scene="2" role="tab" aria-selected="false">
        <span class="tab-icon">🎸</span> Guitar
      </button>
    </div>

    <!-- Horizontal panel track -->
    <div class="hobbies-wrapper" aria-live="polite">
      <div class="hobbies-track" data-track>

        <!-- ─── CYCLING ──────────────────────────────────── -->
        <section class="hobbies-scene" id="cycling" role="tabpanel" aria-label="Cycling">
          <!-- Full-panel animated background illustration -->
          <img
            src="/images/hobbies/cyclist-simple-line.svg"
            alt=""
            aria-hidden="true"
            class="cyclist-bg"
          />
          <div class="scene-inner">
            <p class="hobby-lead">
              Munich is best experienced at 28 km/h. I ride year-round — solo early mornings on the Isar,
              and group rides with <strong>Accross Cycling Club Munich</strong>, where I serve as ride leader
              and help build the club's software infrastructure.
            </p>

            <div class="stats-grid">
              <div class="stat-card">
                <span class="stat-num">4 800<span class="stat-unit"> km</span></span>
                <span class="stat-label">Distance / year</span>
              </div>
              <div class="stat-card">
                <span class="stat-num">42 000<span class="stat-unit"> m</span></span>
                <span class="stat-label">Elevation / year</span>
              </div>
              <div class="stat-card">
                <span class="stat-num">180<span class="stat-unit"> rides</span></span>
                <span class="stat-label">Rides / year</span>
              </div>
            </div>

            <p class="stat-note">Stats are approximate annual averages — not excuses to skip the next ride.</p>

            <div class="hobby-links">
              <a href="https://www.strava.com/athletes/119635546" target="_blank" rel="noopener noreferrer" class="hobby-link-btn">
                View on Strava ↗
              </a>
              <a href="https://acc-clubhub.vercel.app/" target="_blank" rel="noopener noreferrer" class="hobby-link-btn hobby-link-btn--ghost">
                ACC ClubHub ↗
              </a>
            </div>
          </div>
        </section>

        <!-- ─── READING ──────────────────────────────────── -->
        <section class="hobbies-scene" id="reading" role="tabpanel" aria-label="Reading" aria-hidden="true">
          <img
            src="/images/hobbies/book.svg"
            alt=""
            aria-hidden="true"
            class="book-bg"
          />
          <div class="scene-inner">
            <p class="hobby-lead">
              I grew up on wuxia and science fiction. The best books feel like they rearrange
              something inside you — a sentence you come back to years later and understand differently.
            </p>

            <div class="reading-footer">
              <p class="reading-app-note">
                Currently reading on <strong>微信读书 (WeChat Reading)</strong> — the best
                Chinese e-reader app, with decent annotation sync.
              </p>
              <a href="https://weread.qq.com/" target="_blank" rel="noopener noreferrer" class="hobby-link-btn hobby-link-btn--ghost">
                微信读书 ↗
              </a>
            </div>

            <CharacterCarousel />
          </div>
        </section>

        <!-- ─── GUITAR ────────────────────────────────────── -->
        <section class="hobbies-scene" id="guitar" role="tabpanel" aria-label="Guitar" aria-hidden="true">
          <img
            src="/images/hobbies/music-notes.svg"
            alt=""
            aria-hidden="true"
            class="music-bg"
          />
          <div class="scene-inner">
            <p class="hobby-lead">
              Acoustic guitar, mostly self-taught, mostly late at night. I've never composed anything —
              it's not about output. It's about the twenty minutes after a long day when my hands
              do something that doesn't involve a keyboard or a solver. Folk, fingerpicking, the odd
              Hesse-adjacent singer-songwriter mood. Still learning. Probably always will be.
            </p>
          </div>
        </section>

      </div><!-- /track -->
    </div><!-- /wrapper -->

    <!-- Bottom nav arrows -->
    <div class="scene-controls">
      <button class="ctrl-btn ctrl-prev" aria-label="Previous section" disabled>←</button>
      <div class="scene-dots">
        <span class="scene-dot active" data-dot="0"></span>
        <span class="scene-dot" data-dot="1"></span>
        <span class="scene-dot" data-dot="2"></span>
      </div>
      <button class="ctrl-btn ctrl-next" aria-label="Next section">→</button>
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Page wrapper (breaks out of layout container) ─ */
  .hobbies-page {
    max-width: none;
    margin-inline: calc(-1 * var(--page-px, 24px));
    padding-block: 3rem 4rem;
  }

  /* ── Header ─────────────────────────────────────── */
  .hobbies-header {
    padding-inline: var(--page-px, 24px);
    max-width: calc(720px + 2 * var(--page-px, 24px));
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .hobbies-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.15;
    color: var(--fg);
    margin-bottom: 0.625rem;
  }

  .hobbies-intro {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: 52ch;
  }

  /* ── Section tabs ─────────────────────────────────── */
  .scene-tabs {
    display: flex;
    gap: 0.25rem;
    padding-inline: var(--page-px, 24px);
    max-width: calc(720px + 2 * var(--page-px, 24px));
    margin-inline: auto;
    margin-bottom: 0;
    border-bottom: 1px solid var(--border);
  }

  .scene-tab {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .scene-tab:hover { color: var(--fg); }

  .scene-tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .tab-icon { font-size: 1rem; }

  /* ── Wrapper + track ──────────────────────────────── */
  .hobbies-wrapper {
    overflow: hidden;
    position: relative;
    height: 68svh;
    min-height: 420px;
    width: 85%;
    margin-inline: auto;
  }

  .hobbies-track {
    display: flex;
    width: 300%;
    height: 100%;
    transition: transform 0.48s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* ── Individual scenes ────────────────────────────── */
  .hobbies-scene {
    width: 33.333%;
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    position: relative;
    /* Smooth momentum scrolling on iOS */
    -webkit-overflow-scrolling: touch;
    /* Hide scrollbar visually but keep it functional */
    scrollbar-width: none;
  }
  .hobbies-scene::-webkit-scrollbar { display: none; }

  .scene-inner {
    max-width: 720px;
    margin-inline: auto;
    padding: 2.5rem var(--page-px, 24px) 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Shared content styles ────────────────────────── */
  .hobby-lead {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--fg);
    max-width: 65ch;
  }

  /* Stats */
  .stats-grid {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 130px;
  }

  .stat-num {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
  }

  .stat-unit {
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--fg-muted);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  .stat-note {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-style: italic;
  }

  /* Links */
  .hobby-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hobby-link-btn {
    display: inline-block;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
    background: var(--accent);
    color: #fff;
    border: 1.5px solid var(--accent);
  }
  .hobby-link-btn:hover { opacity: 0.88; }
  .hobby-link-btn--ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--border-dark);
  }
  .hobby-link-btn--ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Shared panel background base ──────────────────── */
  .cyclist-bg,
  .book-bg,
  .music-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  /* ── Cycling: animated drift ────────────────────────── */
  .cyclist-bg {
    object-position: center 60%;
    opacity: 0.09;
    transform-origin: center 60%;
    animation: cyclist-drift 14s ease-in-out infinite alternate;
  }

  @keyframes cyclist-drift {
    0%   { transform: scale(1.08) translateX(-2%); }
    50%  { transform: scale(1.12) translateX(0%);  }
    100% { transform: scale(1.08) translateX(2%);  }
  }

  #cycling[aria-hidden="true"] .cyclist-bg { animation-play-state: paused; }

  /* ── Reading: static background ────────────────────── */
  .book-bg {
    object-position: 41.67% center;
    opacity: 0.09;
  }

  /* ── Guitar: floating music notes ───────────────────── */
  .music-bg {
    object-position: center center;
    opacity: 0.22;
    transform-origin: center center;
    animation: notes-float 7s ease-in-out infinite;
  }

  @keyframes notes-float {
    0%   { transform: scale(1.05) translateY(0%)    rotate(-1deg); }
    33%  { transform: scale(1.08) translateY(-2.5%) rotate(0.5deg); }
    66%  { transform: scale(1.06) translateY(-1%)   rotate(-0.5deg); }
    100% { transform: scale(1.05) translateY(0%)    rotate(-1deg); }
  }

  #guitar[aria-hidden="true"] .music-bg { animation-play-state: paused; }

  @media (prefers-reduced-motion: reduce) {
    .cyclist-bg,
    .music-bg { animation: none; }
  }

  /* Dark mode: invert black-stroke SVGs so they show on dark background */
  :global(.theme-dark) .cyclist-bg {
    filter: invert(1);
    opacity: 0.12;
  }

  /* Reading */
  .reading-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .author-card {
    border-left: 3px solid var(--border-dark);
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color 0.15s;
  }
  .author-card:hover { border-left-color: var(--accent); }

  .author-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--fg);
  }

  .author-tag {
    font-size: var(--text-xs);
    color: var(--fg-muted);
    border: 1px solid var(--border-dark);
    border-radius: var(--radius-sm);
    padding: 0.1rem 0.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .author-note {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--fg);
    max-width: 60ch;
  }

  .author-recs {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-style: italic;
  }

  .reading-footer {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
  }

  .reading-app-note {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }


  /* ── Bottom controls ──────────────────────────────── */
  .scene-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding-top: 1.5rem;
    padding-inline: var(--page-px, 24px);
  }

  .ctrl-btn {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--border-dark);
    background: none;
    color: var(--fg);
    font-size: 0.875rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s, color 0.15s;
  }
  .ctrl-btn:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }
  .ctrl-btn:disabled { opacity: 0.28; cursor: not-allowed; }

  .scene-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .scene-dot {
    display: block;
    width: 7px;
    height: 7px;
    border-radius: var(--radius-pill);
    background: var(--border-dark);
    cursor: pointer;
    transition: background 0.18s, transform 0.18s;
  }
  .scene-dot.active {
    background: var(--accent);
    transform: scale(1.35);
  }

  /* ── Reduced motion ───────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hobbies-track { transition: none; }
  }
</style>

<script>
  function initHobbies() {
    const track    = document.querySelector<HTMLElement>('[data-track]');
    const tabs     = Array.from(document.querySelectorAll<HTMLButtonElement>('.scene-tab'));
    const dots     = Array.from(document.querySelectorAll<HTMLElement>('.scene-dot'));
    const scenes   = Array.from(document.querySelectorAll<HTMLElement>('.hobbies-scene'));
    const prevBtn  = document.querySelector<HTMLButtonElement>('.ctrl-prev');
    const nextBtn  = document.querySelector<HTMLButtonElement>('.ctrl-next');
    const wrapper  = document.querySelector<HTMLElement>('.hobbies-wrapper');

    if (!track || !prevBtn || !nextBtn || !wrapper || scenes.length === 0) return;

    let cur = 0;

    function goTo(index: number) {
      if (index < 0 || index >= scenes.length) return;

      scenes[index].scrollTop = 0;
      track.style.transform = `translateX(${-index * (100 / 3)}%)`;
      scenes.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== index)));
      tabs.forEach((t, i) => {
        t.classList.toggle('active', i === index);
        t.setAttribute('aria-selected', String(i === index));
      });
      dots.forEach((d, i) => d.classList.toggle('active', i === index));
      prevBtn.disabled = index === 0;
      nextBtn.disabled = index === scenes.length - 1;
      cur = index;
    }

    tabs.forEach((tab, i) => tab.addEventListener('click', () => goTo(i)));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    prevBtn.addEventListener('click', () => goTo(cur - 1));
    nextBtn.addEventListener('click', () => goTo(cur + 1));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft')  goTo(cur - 1);
      if (e.key === 'ArrowRight') goTo(cur + 1);
    });

    let wheelCooldown = false;
    wrapper.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;
      const scene = scenes[cur];
      const delta = e.deltaY;
      if (Math.abs(delta) < 1) return;

      const atTop    = scene.scrollTop <= 0;
      const atBottom = scene.scrollTop + scene.clientHeight >= scene.scrollHeight - 2;

      if ((delta > 0 && !atBottom) || (delta < 0 && !atTop)) {
        e.preventDefault();
        scene.scrollTop += delta;
        return;
      }

      const canNext = delta > 0 && cur < scenes.length - 1;
      const canPrev = delta < 0 && cur > 0;
      if (!canNext && !canPrev) return;

      e.preventDefault();
      if (wheelCooldown) return;
      wheelCooldown = true;
      setTimeout(() => { wheelCooldown = false; }, 700);
      delta > 0 ? goTo(cur + 1) : goTo(cur - 1);
    }, { passive: false });

    let touchStartX = 0;
    wrapper.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    wrapper.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) dx < 0 ? goTo(cur + 1) : goTo(cur - 1);
    });

    goTo(0);
  }

  document.addEventListener('astro:page-load', initHobbies);
</script>
