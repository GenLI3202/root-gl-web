---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Hobbies · Gen Li" description="Cycling, reading, and guitar — life beyond the whiteboard.">
  <div class="hobbies-page container">

    <!-- Page header -->
    <header class="hobbies-header">
      <h1 class="hobbies-title">Life Beyond the Whiteboard</h1>
      <p class="hobbies-intro">
        Optimisation keeps the mind sharp. Everything below keeps the rest of me alive.
      </p>
    </header>

    <!-- ─── CYCLING ────────────────────────────────── -->
    <section class="hobby-section" id="cycling">
      <div class="hobby-label">
        <span class="hobby-icon">🚴</span>
        <span class="hobby-name">Cycling</span>
      </div>

      <div class="hobby-body">
        <p class="hobby-lead">
          Munich is best experienced at 28 km/h. I ride year-round — solo early mornings on the Isar,
          and group rides with <strong>Accross Cycling Club Munich</strong>, where I serve as ride leader
          and help build the club's software infrastructure.
        </p>

        <!-- Annual stats -->
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-num">4 800<span class="stat-unit"> km</span></span>
            <span class="stat-label">Distance / year</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">42 000<span class="stat-unit"> m</span></span>
            <span class="stat-label">Elevation / year</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">180<span class="stat-unit"> rides</span></span>
            <span class="stat-label">Rides / year</span>
          </div>
        </div>

        <p class="stat-note">Stats are approximate annual averages — not excuses to skip the next ride.</p>

        <div class="hobby-links">
          <a href="https://www.strava.com/athletes/119635546" target="_blank" rel="noopener noreferrer" class="hobby-link-btn">
            View on Strava ↗
          </a>
          <a href="https://acc-clubhub.vercel.app/" target="_blank" rel="noopener noreferrer" class="hobby-link-btn hobby-link-btn--ghost">
            ACC ClubHub ↗
          </a>
        </div>
      </div>
    </section>

    <!-- ─── TRANSITION: wheel rolls away ────────────── -->
    <div class="transition-divider" data-transition="wheel" aria-hidden="true">
      <div class="wheel-track">
        <svg class="wheel-svg" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="30" cy="30" r="27" stroke="currentColor" stroke-width="2.5"/>
          <circle cx="30" cy="30" r="4.5" fill="currentColor"/>
          <line x1="30" y1="3" x2="30" y2="57" stroke="currentColor" stroke-width="1.5"/>
          <line x1="3" y1="30" x2="57" y2="30" stroke="currentColor" stroke-width="1.5"/>
          <line x1="8.1" y1="8.1" x2="51.9" y2="51.9" stroke="currentColor" stroke-width="1.5"/>
          <line x1="51.9" y1="8.1" x2="8.1" y2="51.9" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </div>
    </div>

    <!-- ─── READING ────────────────────────────────── -->
    <section class="hobby-section" id="reading">
      <div class="hobby-label">
        <span class="hobby-icon">📖</span>
        <span class="hobby-name">Reading</span>
      </div>

      <div class="hobby-body">
        <p class="hobby-lead">
          I grew up on wuxia and science fiction. The best books feel like they rearrange
          something inside you — a sentence you come back to years later and understand differently.
        </p>

        <div class="reading-grid">
          <!-- Author cards -->
          <div class="author-card">
            <div class="author-meta">
              <span class="author-name">金庸 Jin Yong</span>
              <span class="author-tag">Wuxia</span>
            </div>
            <p class="author-note">
              Grew up with the Condor Heroes. 侠之大者，为国为民 — heroism is civic, not personal.
              Return to these every few years and notice something new each time.
            </p>
            <p class="author-recs">《射雕英雄传》· 《笑傲江湖》· 《天龙八部》</p>
          </div>

          <div class="author-card">
            <div class="author-meta">
              <span class="author-name">刘慈欣 Liu Cixin</span>
              <span class="author-tag">Sci-Fi</span>
            </div>
            <p class="author-note">
              给岁月以文明，给时光以生命。The Three-Body trilogy broke my sense of scale —
              in the best way possible. Hard SF with genuine philosophical weight.
            </p>
            <p class="author-recs">《三体》· 《流浪地球》· 《朝闻道》</p>
          </div>

          <div class="author-card">
            <div class="author-meta">
              <span class="author-name">Hermann Hesse</span>
              <span class="author-tag">Literature</span>
            </div>
            <p class="author-note">
              <em>Der Vogel kämpft sich aus dem Ei heraus.</em> Read Demian at 20,
              Steppenwolf at 25 — both hit differently. Hesse writes for people who feel
              slightly out of place wherever they are.
            </p>
            <p class="author-recs">Demian · Steppenwolf · Siddhartha</p>
          </div>
        </div>

        <div class="reading-footer">
          <p class="reading-app-note">
            Currently reading on <strong>微信读书 (WeChat Reading)</strong> — the best
            Chinese e-reader app, with decent annotation sync.
          </p>
          <a href="https://weread.qq.com/" target="_blank" rel="noopener noreferrer" class="hobby-link-btn hobby-link-btn--ghost">
            微信读书 ↗
          </a>
        </div>

        <p class="reading-carousel-teaser">
          ✦ <em>Literary Characters Carousel coming soon — watch this space.</em>
        </p>
      </div>
    </section>

    <!-- ─── TRANSITION: book opens → guitar ─────────── -->
    <div class="transition-divider" data-transition="book-guitar" aria-hidden="true">
      <div class="book-guitar-stage">
        <span class="anim-book">📖</span>
        <span class="anim-guitar">🎸</span>
      </div>
    </div>

    <!-- ─── GUITAR ─────────────────────────────────── -->
    <section class="hobby-section" id="guitar">
      <div class="hobby-label">
        <span class="hobby-icon">🎸</span>
        <span class="hobby-name">Guitar</span>
      </div>

      <div class="hobby-body">
        <p class="hobby-lead">
          Acoustic guitar, mostly self-taught, mostly late at night. I've never composed anything —
          it's not about output. It's about the twenty minutes after a long day when my hands
          do something that doesn't involve a keyboard or a solver. Folk, fingerpicking, the odd
          Hesse-adjacent singer-songwriter mood. Still learning. Probably always will be.
        </p>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Page wrapper ────────────────────────────── */
  .hobbies-page {
    padding-block: 4rem 6rem;
  }

  /* ── Page header ─────────────────────────────── */
  .hobbies-header {
    margin-bottom: 4rem;
  }

  .hobbies-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.15;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .hobbies-intro {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: 52ch;
  }

  /* ── Section layout ───────────────────────────── */
  .hobby-section {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .hobby-section {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  /* ── Hobby label (left column) ────────────────── */
  .hobby-label {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    padding-top: 0.2rem;
    position: sticky;
    top: 5rem;
  }

  .hobby-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .hobby-name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--fg);
  }

  /* ── Hobby body (right column) ────────────────── */
  .hobby-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hobby-lead {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--fg);
    max-width: 65ch;
  }

  /* ── Stats (cycling) ──────────────────────────── */
  .stats-grid {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 130px;
  }

  .stat-num {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
  }

  .stat-unit {
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--fg-muted);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  .stat-note {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-style: italic;
  }

  /* ── Links ────────────────────────────────────── */
  .hobby-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hobby-link-btn {
    display: inline-block;
    padding: 0.5rem 1.1rem;
    border-radius: 0.375rem;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition);
    background: var(--accent);
    color: #fff;
    border: 1.5px solid var(--accent);
  }

  .hobby-link-btn:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
  }

  .hobby-link-btn--ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--border-dark);
  }

  .hobby-link-btn--ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Reading grid ─────────────────────────────── */
  .reading-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .author-card {
    border-left: 3px solid var(--border-dark);
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color var(--transition);
  }

  .author-card:hover {
    border-left-color: var(--accent);
  }

  .author-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--fg);
  }

  .author-tag {
    font-size: var(--text-xs);
    color: var(--fg-muted);
    border: 1px solid var(--border-dark);
    border-radius: 0.25rem;
    padding: 0.1rem 0.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .author-note {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--fg);
    max-width: 60ch;
  }

  .author-recs {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-style: italic;
  }

  .reading-footer {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .reading-app-note {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }

  .reading-carousel-teaser {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-style: italic;
  }

  /* ── Transition dividers ─────────────────────────── */
  .transition-divider {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 5rem;
    margin-block: 2rem;
    overflow: hidden;
  }

  /* ── Wheel ────────────────────────────────────────── */
  .wheel-track {
    color: var(--fg-muted);
    width: 60px;
    height: 60px;
  }

  .wheel-svg {
    width: 60px;
    height: 60px;
    display: block;
  }

  @media (prefers-reduced-motion: no-preference) {
    [data-transition="wheel"].animate .wheel-track {
      animation: wheel-translate 0.85s cubic-bezier(0.4, 0, 1, 1) forwards;
    }
    [data-transition="wheel"].animate .wheel-svg {
      animation: wheel-spin 0.85s linear forwards;
    }

    @keyframes wheel-translate {
      0%   { transform: translateX(0);      opacity: 1; }
      70%  { opacity: 1; }
      100% { transform: translateX(220px);  opacity: 0; }
    }

    @keyframes wheel-spin {
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(720deg); }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-transition="wheel"].animate .wheel-track {
      opacity: 0;
      transition: opacity 0.3s;
    }
  }

  /* ── Book → Guitar ────────────────────────────────── */
  .book-guitar-stage {
    position: relative;
    width: 60px;
    height: 60px;
  }

  .anim-book,
  .anim-guitar {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    line-height: 1;
  }

  .anim-guitar {
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    [data-transition="book-guitar"].animate .anim-book {
      animation: book-open 0.6s ease-in forwards;
    }
    [data-transition="book-guitar"].animate .anim-guitar {
      animation: guitar-emerge 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.45s forwards;
    }

    @keyframes book-open {
      0%   { transform: perspective(300px) rotateY(0deg)   scale(1);   opacity: 1; }
      45%  { transform: perspective(300px) rotateY(-90deg) scale(0.8); opacity: 0.4; }
      100% { transform: perspective(300px) rotateY(-180deg) scale(0);  opacity: 0; }
    }

    @keyframes guitar-emerge {
      0%   { transform: scale(0.3) translateY(16px) rotate(-15deg); opacity: 0; }
      70%  { transform: scale(1.12) translateY(-3px) rotate(4deg);  opacity: 1; }
      100% { transform: scale(1)   translateY(0)    rotate(0deg);   opacity: 1; }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-transition="book-guitar"].animate .anim-book  { opacity: 0; transition: opacity 0.3s; }
    [data-transition="book-guitar"].animate .anim-guitar { opacity: 1; transition: opacity 0.3s 0.3s; }
  }
</style>

<script>
  const dividers = document.querySelectorAll<HTMLElement>('.transition-divider');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.6 }
  );

  dividers.forEach((el) => observer.observe(el));
</script>
